TWITCH_CLIENT_ID=your_client_id_here
TWITCH_CLIENT_SECRET=your_client_secret_here
# Optional: fetch clips for a specific game or broadcaster by default
# TOP_GAME_ID=123456
# TOP_BROADCASTER_ID=123456
# Optional default game name used for voiceover and clip lookups
# GAME_NAME=Valorant

# Period in minutes used when not provided by the client
PERIOD_MINUTES=60

# Video MCP server settings to stitch clips and add voiceover
VIDEO_MCP_BASE_URL=https://your-video-mcp-server.example.com
VIDEO_MCP_API_KEY=your_api_key_here